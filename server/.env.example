# Copy to .env (or set these however your deployment injects env vars) and
# fill in real values. Every value here has a dev-friendly default in
# server/src/config.ts — this file exists so a production deployment has
# one place to see every knob, not five files each with one.

# --- Core (required in any real deployment) ---
NODE_ENV=production
PORT=3000
# Yjs collaboration relay — a SEPARATE port from the main API. Your
# reverse proxy must route both, and the collab port needs WebSocket
# upgrade support, not just plain HTTP proxying.
COLLAB_PORT=3001
DATABASE_URL=postgres://chapters:chapters@localhost:5432/chapters
# Where OKF note files and local-path repository clones/scratch live.
DATA_DIR=/data/chapters

# --- Secrets (generate real values; never commit them) ---
# One-time instance-setup token. Omit to auto-generate and print to the
# boot log on first run instead (only the log ever shows it in plaintext).
SETUP_TOKEN=
# 32-byte (64 hex char) key encrypting private-repo git credentials and
# webhook secrets at rest. Required only once you actually configure a
# private repository or a webhook — but there is no rotation story, so
# generate and back this up before you need it: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=

# --- Email (signup verification, password reset, notifications) ---
# Omitted SMTP_HOST means mail is recorded in-process, never sent — fine
# for a first boot, not for real signup/reset flows.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=chapters@localhost

# --- Embeddings ---
# 'local' (real ONNX model, self-hosted, content never leaves the
# instance) or 'fake' (deterministic, dev/test only — do not use in
# production, search/graph relevance depends on this). Defaults to
# 'local' automatically when NODE_ENV=production.
EMBEDDINGS=local
SEMANTIC_THRESHOLD=0.75
SEMANTIC_K=8

# --- Repository ingestion tuning ---
LOCAL_REPOS_ROOT=/data/chapters/local-repos
POLL_INTERVAL_MS=300000
WEBHOOK_STALE_THRESHOLD_MS=600000

# --- Collaboration / MCP / export tuning ---
COLLAB_DEBOUNCE_MS=2000
MCP_RATE_LIMIT=120
EXPORT_LINK_TTL_HOURS=24

# --- CORS ---
# Comma-separated list of origins allowed to call the API cross-origin
# (e.g. a UI served from a different domain/port than the API). Leave
# unset for same-origin-only — the common self-hosted pattern where the
# UI is reverse-proxied under the same domain as the API needs no CORS
# configuration at all.
CORS_ORIGIN=
